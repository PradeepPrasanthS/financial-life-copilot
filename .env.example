# ==========================================
# Financial Life Copilot Environment Settings
# ==========================================

# --- Backend Settings (Python FastAPI / ADK) ---
# Your Google Cloud Project ID (run `gcloud config get project` to retrieve)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Enable Vertex AI Native Generative Gateway
GOOGLE_GENAI_USE_VERTEXAI=True

# Environment setting (development / production)
ENV=development

# CORS settings for API access
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: GCS bucket name for archiving session files (created during deploy)
# LOGS_BUCKET_NAME=your-gcs-logs-bucket


# --- Frontend Settings (Next.js) ---
# Next.js public API target pointing to the backend
NEXT_PUBLIC_API_URL=http://localhost:8000
